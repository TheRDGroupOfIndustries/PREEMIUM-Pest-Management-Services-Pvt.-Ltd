
{
	"redirects": [
		{
			"source": "/(.*)",
			"has": [
				{ "type": "host", "value": "preemiumpestmangagement.com" }
			],
			"destination": "https://preemiumpestmanagementservices.com/$1",
			"permanent": true
		},
		{
			"source": "/(.*)",
			"has": [
				{ "type": "host", "value": "www.preemiumpestmangagement.com" }
			],
			"destination": "https://preemiumpestmanagementservices.com/$1",
			"permanent": true
		}
	],
	"rewrites": [
		{"source":"/(.*)", "destination": "/"}
	]
} 
